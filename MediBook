.hist-det{font-size:.73rem;color:var(--i2);line-height:1.75}
.hist-acts{display:flex;gap:.4rem;margin-top:.55rem}
.hbtn{font-size:.68rem;font-weight:600;padding:.24rem .68rem;border-radius:var(--pill);cursor:pointer;transition:all .14s}
.hbtn-c{background:none;border:1.5px solid #f09595;color:#a32d2d}.hbtn-c:hover{background:#fcebeb}
.hbtn-r{background:none;border:1.5px solid rgba(93,202,165,.5);color:var(--mg)}.hbtn-r:hover{background:var(--ml)}

/* TOAST */
.toast{position:fixed;bottom:1.4rem;right:1.4rem;z-index:999;background:var(--ink);color:var(--wh);border-radius:var(--r);padding:.72rem 1.1rem;font-size:.78rem;box-shadow:0 6px 24px rgba(0,0,0,.2);max-width:280px;transform:translateY(16px);opacity:0;transition:all .28s ease;pointer-events:none;border-left:3px solid var(--mm)}
.toast.show{transform:translateY(0);opacity:1}.toast.err{border-left-color:#e24b4a}

/* RESPONSIVE */
@media(max-width:860px){
