  // ── State ────────────────────────────────────────────────
  const [docs,      setDocs]      = useState(() => DOCTORS_DATA.map(d=>({...d,slots:{...d.slots,booked:[...d.slots.booked]}})));
  const [selSlots,  setSelSlots]  = useState({});   // { docId: slotIdx }
  const [search,    setSearch]    = useState("");
  const [specF,     setSpecF]     = useState("");
  const [locF,      setLocF]      = useState("");
  const [chipF,     setChipF]     = useState("");
  const [sort,      setSort]      = useState("rec");
  const [actSpec,   setActSpec]   = useState("");
  const [bookCtx,   setBookCtx]   = useState(null); // { doc, idx }
  const [profDoc,   setProfDoc]   = useState(null);
  const [showHist,  setShowHist]  = useState(false);
  const [showSucc,  setShowSucc]  = useState(false);
  const [lastBk,    setLastBk]    = useState(null);
  const [bookings,  setBookings]  = useState([]);
  const [patN,  setPatN]  = useState("");
  const [patP,  setPatP]  = useState("");
  const [patNt, setPatNt] = useState("");
  const [toast, setToast] = useState({msg:"",type:"s",show:false});
  const [secs,  setSecs]  = useState(0);
  const toastRef = useRef(null);

  // ── Live timer ───────────────────────────────────────────
  useEffect(()=>{
    const t = setInterval(()=>setSecs(s=>s+1),1000);
    return ()=>clearInterval(t);
  },[]);

  // ── Live slot simulation (fires every 15 seconds) ────────
  useEffect(()=>{
    const t = setInterval(()=>{
      setDocs(prev=>{
        const next = prev.map(d=>({...d,slots:{...d.slots,booked:[...d.slots.booked]}}));
        const d = next[Math.floor(Math.random()*next.length)];
        const total = d.slots.today.length; if(!total) return next;
        const ri = Math.floor(Math.random()*total);
        const bi = d.slots.booked.indexOf(ri);
        if(bi===-1 && Math.random()>.55){
          d.slots.booked.push(ri);
          showT(`${d.slots.today[ri]} with ${d.name} just booked`,"s");
        } else if(bi!==-1 && Math.random()>.5){
          d.slots.booked.splice(bi,1);
          showT(`Slot freed: ${d.slots.today[ri]} with ${d.name}`,"s");
        }
        setSecs(0);
        return next;
      });
    },15000);
    return ()=>clearInterval(t);
  },[]);

  // ── Toast helper ─────────────────────────────────────────
  const showT = useCallback((msg,type="s")=>{
    if(toastRef.current) clearTimeout(toastRef.current);
    setToast({msg,type,show:true});
    toastRef.current = setTimeout(()=>setToast(t=>({...t,show:false})),3200);
  },[]);

  // ── Filter & sort ────────────────────────────────────────
  const filtered = useCallback(()=>{
    const q = search.toLowerCase();
    let res = docs.filter(d=>{
      const ms = !q||d.name.toLowerCase().includes(q)||d.spec.toLowerCase().includes(q)||d.hosp.toLowerCase().includes(q)||d.treats.some(t=>t.toLowerCase().includes(q));
      const msp = !specF || d.spec===specF;
      const ml  = !locF  || d.area===locF;
      let mc = true;
      if(chipF==="avail")  mc = d.avail;
      if(chipF==="top")    mc = d.rec>=94;
      if(chipF==="online") mc = d.online;
      if(chipF==="cheap")  mc = d.fee<=700;
      return ms&&msp&&ml&&mc;
    });
    if(sort==="rec")     res.sort((a,b)=>b.rec-a.rec);
    if(sort==="stories") res.sort((a,b)=>b.stories-a.stories);
    if(sort==="fee")     res.sort((a,b)=>a.fee-b.fee);
    if(sort==="exp")     res.sort((a,b)=>b.exp-a.exp);
    return res;
  },[docs,search,specF,locF,chipF,sort]);

  // ── Slot selection ───────────────────────────────────────
  const pickSlot = useCallback((docId,idx)=>{
    setSelSlots(p=>{ const n={...p}; if(n[docId]===idx) delete n[docId]; else n[docId]=idx; return n; });
  },[]);

  // ── Open booking modal ───────────────────────────────────
  const openBook = (doc,idx) => {
    setBookCtx({doc,idx});
    setPatN(""); setPatP(""); setPatNt("");
    setShowSucc(false);
  };

  // ── Confirm booking ──────────────────────────────────────
  const confirmBook = () => {
    if(!patN.trim()||!patP.trim()){ showT("Please enter your name and phone number","e"); return; }
    const {doc,idx} = bookCtx;
    setDocs(prev=>prev.map(d=>{
      if(d.id!==doc.id) return d;
      const b = d.slots.booked.includes(idx) ? d.slots.booked : [...d.slots.booked,idx];
      return {...d,slots:{...d.slots,booked:b}};
    }));
    setSelSlots(p=>{ const n={...p}; delete n[doc.id]; return n; });
    const ref = genRef();
    const bk = {ref,docId:doc.id,docName:doc.name,spec:doc.spec,hosp:doc.hosp,slotTime:doc.slots.today[idx],date:todayStr(),patN:patN.trim(),patP:patP.trim(),note:patNt.trim(),status:"confirmed"};
    setBookings(p=>[bk,...p]);
    setLastBk(bk); setShowSucc(true); setSecs(0);
    showT(`Appointment confirmed! Ref: ${ref}`,"s");
  };

  // ── Cancel booking ───────────────────────────────────────
  const cancelBk = (ref) => {
    const bk = bookings.find(b=>b.ref===ref);
    setBookings(p=>p.map(b=>b.ref===ref?{...b,status:"cancelled"}:b));
    if(bk){
      setDocs(p=>p.map(d=>{
        if(d.id!==bk.docId) return d;
        const si = d.slots.today.indexOf(bk.slotTime);
        if(si===-1) return d;
        return {...d,slots:{...d.slots,booked:d.slots.booked.filter(i=>i!==si)}};
      }));
    }
    showT("Appointment cancelled","s");
  };

  const clearFilters = () => { setSearch(""); setSpecF(""); setLocF(""); setChipF(""); setActSpec(""); };

  // ── Derived values ───────────────────────────────────────
  const fdocs  = filtered();
  const confN  = bookings.filter(b=>b.status==="confirmed").length;

  // ─────────────────────────────────────────────────────────
  // RENDER
  // ─────────────────────────────────────────────────────────
  return (
    <>
      {/* Inject styles */}
      <style>{STYLES}</style>

      {/* ── LIVE TICKER ── */}
      <div className="ticker">
        <div className="ticker-label"><span className="live-dot"/>Live</div>
        <div className="ticker-track">
          <div className="ticker-inner">
            {[...TICKS,...TICKS].map(([a,b],i)=>(
              <span className="t-item" key={i}><b>{a}</b> — {b}</span>
            ))}
          </div>
        </div>
      </div>

      {/* ── NAV ── */}
      <nav className="nav">
        <div className="nav-logo" onClick={()=>goTo("hero")}>
          <span className="logo-dot"/>MediBook
        </div>
        <ul className="nav-links">
          {[["features","Features"],["how","How it works"],["specialties","Specialties"],["doctors","Doctors"]].map(([id,lbl])=>(
            <li key={id}><button onClick={()=>goTo(id)}>{lbl}</button></li>
          ))}
        </ul>
        <div className="nav-right">
          <button className="nav-hist" onClick={()=>setShowHist(true)}>
            📋 My Bookings
            {confN>0 && <span className="nbadge">{confN}</span>}
          </button>
          <button className="nav-book" onClick={()=>goTo("doctors")}>Book Now</button>
        </div>
      </nav>

      {/* ── HERO ── */}
      <div id="hero">
        <div className="hero">
          <div>
            <div className="eyebrow"><span className="eye-dot"/>Healthcare, simplified</div>
            <h1>Find your doctor,<br/><em>book in minutes</em></h1>
            <p className="hero-desc">
              Search 500+ verified doctors across Hyderabad by specialty or location,
              view real-time slot availability, and book your appointment — instantly.
            </p>
            <div className="hero-actions">
              <button className="btn-primary" onClick={()=>goTo("doctors")}>Book an Appointment</button>
              <button className="btn-ghost"   onClick={()=>goTo("how")}>How it works</button>
            </div>
            <div className="hero-tags">
              {["Doctor Search","Specialty Filter"].map(t=><span key={t} className="tag tag-g">{t}</span>)}
              {["Real-time Slots","Instant Booking"].map(t=><span key={t} className="tag tag-p">{t}</span>)}
              <span className="tag tag-a">Booking History</span>
            </div>
          </div>

          {/* Live hero panel */}
          <div className="hero-panel">
            <div className="panel-head">
              <div className="panel-title">Available right now</div>
              <div className="live-pill"><span className="live-dot"/>LIVE</div>
            </div>
            <div className="panel-rows">
              {docs.filter(d=>d.avail).slice(0,5).map(d=>(
                <div className="panel-row" key={d.id}>
                  <div className={`p-av ${d.av}`}>{d.ini}</div>
                  <div className="p-info">
                    <div className="p-name">{d.name}</div>
                    <div className="p-spec">{d.spec} · {d.exp} yrs</div>
                  </div>
                  <div className={`p-avail ${nextSlot(d)?"p-yes":"p-no"}`}>
                    {nextSlot(d) || "Full"}
                  </div>
                </div>
              ))}
            </div>
            <div className="panel-foot">
              <span className="panel-foot-txt">Updated <b>{updTxt(secs)}</b></span>
              <span className="panel-foot-txt">{docs.filter(d=>d.online).length} online</span>
            </div>
          </div>
        </div>
      </div>

      {/* ── SEARCH BAR ── */}
      <div className="search-wrap">
        <div className="search-bar">
          <span style={{color:"var(--i3)",flexShrink:0}}>🔍</span>
          <input
            type="text"
            placeholder="Search doctor, specialty, condition..."
            value={search}
            onChange={e=>setSearch(e.target.value)}
          />
          <div className="search-div"/>
          <select value={specF} onChange={e=>{setSpecF(e.target.value);setActSpec(e.target.value);}}>
            <option value="">All Specialties</option>
            {SPECS.map(s=><option key={s.n}>{s.n}</option>)}
          </select>
          <div className="search-div"/>
          <select value={locF} onChange={e=>setLocF(e.target.value)}>
            <option value="">All Areas</option>
            {AREAS.map(a=><option key={a}>{a}</option>)}
          </select>
          <button className="search-btn" onClick={()=>goTo("doctors")}>Find Doctors</button>
        </div>
      </div>

      {/* ── SPECIALTIES ── */}
      <div className="section" id="specialties">
        <div className="sec-lbl">Browse by specialty</div>
        <h2 className="sec-title">Find the right specialist</h2>
        <div className="spec-grid">
          {SPECS.map(s=>(
            <div
              key={s.n}
              className={`spec-card${actSpec===s.n?" active":""}`}
              onClick={()=>{ setActSpec(s.n); setSpecF(s.n); goTo("doctors"); }}
            >
              <span className="spec-icon">{s.icon}</span>
              <div className="spec-name">{s.n}</div>
              <div className="spec-count">{s.cnt} doctors</div>
            </div>
          ))}
        </div>
      </div>

      {/* ── DOCTORS ── */}
      <div className="section" id="doctors">
        <div className="sec-lbl">Verified professionals · Hyderabad</div>
        <h2 className="sec-title">Top-rated doctors near you</h2>

        {/* Toolbar */}
        <div className="toolbar">
          <div className="chips">
            {[["","All"],["avail","Available Today"],["top","Top Rated (94%+)"],["online","Online Consult"],["cheap","Affordable (≤₹700)"]].map(([v,l])=>(
              <button key={v} className={`chip${chipF===v?" on":""}`} onClick={()=>setChipF(v)}>{l}</button>
            ))}
            {(specF||locF||search) && (
              <button className="chip chip-clr" onClick={clearFilters}>✕ Clear filters</button>
            )}
          </div>
          <select className="sort-sel" value={sort} onChange={e=>setSort(e.target.value)}>
            <option value="rec">Most recommended</option>
            <option value="stories">Most patient stories</option>
            <option value="fee">Lowest fee</option>
            <option value="exp">Most experienced</option>
          </select>
        </div>

        {/* Grid */}
        <div className="docs-grid">
          {fdocs.length===0
            ? <div className="no-results">No doctors matched your search. Try adjusting the filters.</div>
            : fdocs.map(doc=>(
                <DocCard
                  key={doc.id}
                  doc={doc}
                  selSlot={selSlots[doc.id]}
                  onPick={idx=>pickSlot(doc.id,idx)}
                  onBook={()=>openBook(doc,selSlots[doc.id])}
                  onProfile={()=>setProfDoc(docs.find(d=>d.id===doc.id))}
                  free={freeN(doc)}
                />
              ))
          }
        </div>
      </div>

      {/* ── FEATURES ── */}
      <div className="section" id="features">
        <div className="sec-lbl">What we offer</div>
        <h2 className="sec-title">Everything you need, all in one place</h2>
        <div className="feat-grid">
          {FEATURES.map(f=>(
            <div key={f.num} className={`feat-card ${f.cc}`}>
              <div className="feat-num">{f.num}</div>
              <div className={`feat-icon ${f.ic}`}>{f.e}</div>
              <h3>{f.t}</h3>
              <p>{f.d}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── HOW IT WORKS ── */}
      <div className="section" id="how">
        <div className="sec-lbl">Simple steps</div>
        <h2 className="sec-title">How it works</h2>
        <div className="steps">
          {[
            ["1","Search a Doctor","Enter a name, specialty, or condition to find verified doctors near you."],
            ["2","Pick a Slot","Browse live-updated time slots and choose what works best for you."],
            ["3","Confirm Booking","Enter your details and confirm in one click — done in under a minute."],
            ["4","Get a Reminder","Receive a notification before your appointment — never miss a visit."],
          ].map(([n,t,d])=>(
            <div className="step" key={n}>
              <div className="step-num">{n}</div>
              <h4>{t}</h4>
              <p>{d}</p>
            </div>
          ))}
        </div>
      </div>

      {/* ── STATS ── */}
      <div className="stats-bar">
        {[["500+","Verified Doctors"],["20k+","Appointments Booked"],["15+","Specialties"],["4.9★","Avg Rating"]].map(([n,l])=>(
          <div className="stat" key={l}>
            <span className="stat-num">{n}</span>
            <div className="stat-lbl">{l}</div>
          </div>
        ))}
      </div>

      {/* ── FOOTER ── */}
      <div className="footer">
        <p>Built with <b>React.js · Node.js · Express.js · REST APIs</b> | MediBook © 2025</p>
        <p style={{marginTop:5}}>Doctor data sourced from Practo, Apollo 247, Skedoc — Hyderabad</p>
      </div>

      {/* ════════════════════════════════════════════════════
          MODALS
      ════════════════════════════════════════════════════ */}

      {/* BOOKING MODAL */}
      {bookCtx && (
        <div className="overlay open" onClick={e=>{if(e.target.classList.contains("overlay"))setBookCtx(null);}}>
          <div className="modal">
            <div className="m-head">
              <h3>{showSucc ? "Booking Confirmed!" : "Book Appointment"}</h3>
              <button className="m-close" onClick={()=>setBookCtx(null)}>✕</button>
            </div>
            <div className="m-body">
              {!showSucc ? (
                <>
                  <div className="m-doc-row">
                    <div className={`m-doc-av ${bookCtx.doc.av}`}>{bookCtx.doc.ini}</div>
                    <div>
                      <div className="m-doc-name">{bookCtx.doc.name}</div>
                      <div className="m-doc-sub">{bookCtx.doc.spec} · {bookCtx.doc.hosp}</div>
                    </div>
                  </div>
                  <div className="slot-confirm">
                    📅 {todayStr()} at <b style={{marginLeft:4}}>{bookCtx.doc.slots.today[bookCtx.idx]}</b>
                  </div>
                  <div className="field">
                    <label>Full Name *</label>
                    <input type="text" placeholder="e.g. Rahul Sharma" value={patN} onChange={e=>setPatN(e.target.value)}/>
                  </div>
                  <div className="field">
                    <label>Phone Number *</label>
                    <input type="tel" placeholder="+91 98765 43210" value={patP} onChange={e=>setPatP(e.target.value)}/>
                  </div>
                  <div className="field">
                    <label>Reason / Symptoms (optional)</label>
                    <textarea placeholder="Brief description of your concern..." value={patNt} onChange={e=>setPatNt(e.target.value)}/>
                  </div>
                  <button className="confirm-btn" onClick={confirmBook}>Confirm Appointment</button>
                </>
              ) : (
                <div className="success">
                  <div className="s-icon">✓</div>
                  <h3>You're all set!</h3>
                  <p>Your appointment has been booked. Check My Bookings for details.</p>
                  {lastBk && (
                    <div className="appt-box">
                      <b>Doctor:</b> {lastBk.docName}<br/>
                      <b>Specialty:</b> {lastBk.spec}<br/>
                      <b>Hospital:</b> {lastBk.hosp}<br/>
                      <b>Date:</b> {lastBk.date} · <b>Time:</b> {lastBk.slotTime}<br/>
                      <b>Patient:</b> {lastBk.patN} · <b>Ref No:</b> {lastBk.ref}
                    </div>
                  )}
                  <button className="confirm-btn" onClick={()=>setBookCtx(null)}>Done</button>
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      {/* PROFILE MODAL */}
      {profDoc && (
        <div className="overlay open" onClick={e=>{if(e.target.classList.contains("overlay"))setProfDoc(null);}}>
          <div className="modal modal-lg">
            <div className="m-head">
              <h3>Doctor Profile</h3>
              <button className="m-close" onClick={()=>setProfDoc(null)}>✕</button>
            </div>
            <div className="prof-scroll">
              <div className="prof-hero">
                <div className={`prof-av ${profDoc.av}`}>{profDoc.ini}</div>
                <div className="prof-title">
                  <div className="pn">{profDoc.name}</div>
                  <div className="ps">{profDoc.spec} · {profDoc.exp} yrs · {profDoc.hosp}</div>
                  <div className="pr">{"★".repeat(5)} {profDoc.rec}% recommend · {profDoc.stories} stories</div>
                </div>
              </div>
              <div className="prof-body">
                <div className="prof-sec">
                  <h4>About</h4>
                  <p>{profDoc.about}</p>
                </div>
                <div className="prof-sec">
                  <h4>Key Details</h4>
                  <div className="info-grid">
                    {[
                      ["Experience", profDoc.exp+" years"],
                      ["Consult Fee","₹"+profDoc.fee],
                      ["Online Consult", profDoc.online?"Yes ✓":"No"],
                      ["Available Today", profDoc.avail?"Yes ✓":"Tomorrow"],
                    ].map(([k,v])=>(
                      <div className="info-item" key={k}>
                        <div className="key">{k}</div><div className="val">{v}</div>
                      </div>
                    ))}
                    <div className="info-item" style={{gridColumn:"1/-1"}}>
                      <div className="key">Qualifications</div>
                      <div className="val" style={{fontWeight:400,fontSize:".76rem"}}>{profDoc.quali.join(" · ")}</div>
                    </div>
                    <div className="info-item" style={{gridColumn:"1/-1"}}>
                      <div className="key">Languages</div>
                      <div className="val" style={{fontWeight:400}}>{profDoc.langs.join(", ")}</div>
                    </div>
                  </div>
                </div>
                <div className="prof-sec">
                  <h4>Treats</h4>
                  <div className="treats-row">
                    {profDoc.treats.map(t=><span className="treat-tag" key={t}>{t}</span>)}
                  </div>
                </div>
                {profDoc.badges.length>0 && (
                  <div className="prof-sec">
                    <h4>Recognitions</h4>
                    <div className="badge-row">
                      {profDoc.badges.map(b=><span className="honor-tag" key={b}>{b}</span>)}
                    </div>
                  </div>
                )}
                <div className="prof-sec">
                  <h4>Patient Reviews</h4>
                  {profDoc.reviews.map((r,i)=>(
                    <div className="review-card" key={i}>
                      <div className="rev-top">
                        <span className="rev-name">{r.n}</span>
                        <span className="rev-stars">{"★".repeat(r.s)}</span>
                        <span className="rev-date">{r.d}</span>
                      </div>
                      <div className="rev-text">{r.t}</div>
                    </div>
                  ))}
                </div>
                <div className="prof-sec">
                  <h4>Available Slots — Today</h4>
                  <div className="slot-row">
                    {profDoc.slots.today.map((t,i)=>{
                      const live = docs.find(d=>d.id===profDoc.id);
                      const bk   = live.slots.booked.includes(i);
                      const ss   = selSlots[profDoc.id]===i;
                      return (
                        <span
                          key={i}
                          className={`slot ${bk?"slot-booked":ss?"slot-selected":"slot-free"}`}
                          onClick={()=>!bk&&pickSlot(profDoc.id,i)}
                        >{t}</span>
                      );
                    })}
                  </div>
                  {selSlots[profDoc.id]!==undefined && (
                    <button
                      className="confirm-btn"
                      style={{marginTop:"0.85rem"}}
                      onClick={()=>{
                        setProfDoc(null);
                        const live = docs.find(d=>d.id===profDoc.id);
                        openBook(live,selSlots[profDoc.id]);
                      }}
                    >
                      Book Selected Slot
                    </button>
                  )}
                </div>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* HISTORY MODAL */}
      {showHist && (
        <div className="overlay open" onClick={e=>{if(e.target.classList.contains("overlay"))setShowHist(false);}}>
          <div className="modal modal-hist">
            <div className="m-head">
              <h3>My Appointments</h3>
              <button className="m-close" onClick={()=>setShowHist(false)}>✕</button>
            </div>
            <div className="m-body">
              {bookings.length===0
                ? <div className="hist-empty">No bookings yet.<br/>Book your first appointment above!</div>
                : <div className="hist-list">
                    {bookings.map(b=>(
                      <div className="hist-card" key={b.ref}>
                        <div className="hist-top">
                          <span className="hist-name">{b.docName}</span>
                          <span className={`hist-st ${b.status==="confirmed"?"st-ok":"st-xx"}`}>
                            {b.status==="confirmed" ? "✓ Confirmed" : "✕ Cancelled"}
                          </span>
                        </div>
                        <div className="hist-det">
                          <b>{b.spec}</b> · {b.hosp}<br/>
                          📅 {b.date} · ⏰ {b.slotTime}<br/>
                          Patient: {b.patN} | Ref: <b>{b.ref}</b>
                          {b.note && <><br/>Note: {b.note}</>}
                        </div>
                        {b.status==="confirmed" && (
                          <div className="hist-acts">
                            <button className="hbtn hbtn-c" onClick={()=>cancelBk(b.ref)}>Cancel</button>
                            <button className="hbtn hbtn-r" onClick={()=>{ setShowHist(false); goTo("doctors"); showT("Select a new slot to reschedule","s"); }}>
                              Reschedule
                            </button>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
              }
            </div>
          </div>
        </div>
      )}

      {/* TOAST */}
      <div className={`toast${toast.show?" show":""}${toast.type==="e"?" err":""}`}>
        {toast.msg}
      </div>
    </>
  );
}

// ─────────────────────────────────────────────────────────────
// 5. DOCTOR CARD COMPONENT
// ─────────────────────────────────────────────────────────────
function DocCard({ doc, selSlot, onPick, onBook, onProfile, free }) {
  return (
    <div className="doc-card">
      <div className="doc-top">
        <div className={`doc-av ${doc.av}`}>{doc.ini}</div>
        <div className="doc-info">
          <div className="doc-name-row">
            <span className="doc-name">{doc.name}</span>
            {doc.online && <span className="online-pill">Online</span>}
          </div>
          <div className="doc-spec">{doc.spec} · {doc.exp} yrs · {doc.hosp}</div>
          <div className="doc-meta">
            <span className="doc-rating">★ {doc.rec}% ({doc.stories})</span>
            <span className="doc-ver">✓ Verified</span>
            {doc.badges.includes("Practo Assured") && <span className="doc-badge">Practo Assured</span>}
            {doc.badges.includes("Practo One")     && <span className="doc-badge">Practo One</span>}
            {doc.badges.includes("Padma Bhushan")  && <span className="doc-badge">Padma Bhushan</span>}
          </div>
          <div className="doc-quals">{doc.quali.slice(0,2).join(" · ")}</div>
        </div>
      </div>

      <div className="doc-slots">
        <div className="slots-lbl">
          <span className={`avail-dot ${doc.avail&&free>0?"dot-on":"dot-off"}`}/>
          {doc.avail && free>0
            ? `Available today — ${free} slot${free!==1?"s":""} left`
            : "Next available: Tomorrow"}
          &nbsp;·&nbsp;₹{doc.fee}
        </div>
        <div className="slot-row">
          {doc.slots.today.map((t,i)=>{
            const bk = doc.slots.booked.includes(i);
            const ss = selSlot===i;
            return (
              <span
                key={i}
                className={`slot ${bk?"slot-booked":ss?"slot-selected":"slot-free"}`}
                onClick={()=>!bk&&onPick(i)}
              >{t}</span>
            );
          })}
        </div>
      </div>

      <div className="doc-foot">
        <div className="fee-txt">Fee <b>₹{doc.fee}</b></div>
        <div className="foot-btns">
          <button className="view-btn" onClick={onProfile}>View Profile</button>
          {selSlot !== undefined
            ? <button className="book-btn" onClick={onBook}>Book {doc.slots.today[selSlot]}</button>
            : <span className="no-slot-hint">Select a slot →</span>
          }
        </div>
      </div>
    </div>
  );
}
