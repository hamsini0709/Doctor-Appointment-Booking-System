import { useState, useEffect, useRef, useCallback } from "react";

// ─────────────────────────────────────────────────────────────
// 1. STYLES  (injected via <style> tag so the file is self-contained)
// ─────────────────────────────────────────────────────────────
const STYLES = `
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
:root{
  --mg:#0f6e56;--mg2:#1a9e7a;--ml:#d2f5ec;--mm:#5dcaa5;
  --pk:#fbeaf0;--pkd:#72243e;--pkm:#ed93b1;
  --am:#faeeda;--amd:#633806;--amm:#ef9f27;
  --bl:#e6f1fb;--bld:#0c447c;--blm:#378add;
  --pu:#eeedfe;--pud:#3c3489;--pum:#7f77dd;
  --co:#faece7;--cod:#711b13;--com:#d85a30;
  --cr:#fdf9f4;--wh:#ffffff;
  --ink:#1c1c1c;--i2:#4a4a4a;--i3:#888780;
  --bd:rgba(0,0,0,.08);--bds:rgba(0,0,0,.14);
  --r:10px;--rl:16px;--pill:999px;
  --sh:0 4px 24px rgba(0,0,0,.07);--sh2:0 10px 40px rgba(0,0,0,.11);
}
body{font-family:'DM Sans',sans-serif;background:var(--cr);color:var(--ink);overflow-x:hidden;-webkit-font-smoothing:antialiased}
button,input,select,textarea{font-family:'DM Sans',sans-serif}

/* TICKER */
.ticker{background:var(--mg);padding:.42rem 1.2rem;display:flex;align-items:center;gap:.8rem;overflow:hidden}
.ticker-label{font-size:.65rem;font-weight:600;color:rgba(255,255,255,.65);text-transform:uppercase;letter-spacing:.7px;white-space:nowrap;display:flex;align-items:center;gap:5px;flex-shrink:0}
.live-dot{width:6px;height:6px;border-radius:50%;background:#7fffd4;animation:pulse 1.6s infinite}
.ticker-track{overflow:hidden;flex:1}
.ticker-inner{display:flex;gap:2.2rem;white-space:nowrap;animation:ticker 30s linear infinite}
.ticker-inner:hover{animation-play-state:paused}
.t-item{font-size:.72rem;color:rgba(255,255,255,.82)}
.t-item b{color:#fff}
@keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.75)}}

/* NAV */
.nav{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:.8rem 4vw;background:rgba(253,249,244,.94);backdrop-filter:blur(16px);border-bottom:1px solid rgba(93,202,165,.18)}
.nav-logo{font-family:'DM Serif Display',serif;font-size:1.45rem;color:var(--mg);display:flex;align-items:center;gap:7px;cursor:pointer}
.logo-dot{width:9px;height:9px;border-radius:50%;background:var(--pkm);display:inline-block}
.nav-links{display:flex;gap:1.6rem;list-style:none}
.nav-links button{background:none;border:none;font-size:.88rem;font-weight:500;color:var(--i2);cursor:pointer;transition:color .18s;padding:0}
.nav-links button:hover{color:var(--mg)}
.nav-right{display:flex;align-items:center;gap:.7rem}
.nav-hist{display:flex;align-items:center;gap:5px;background:none;border:1.5px solid var(--bds);border-radius:var(--pill);padding:.36rem .9rem;font-size:.78rem;font-weight:500;color:var(--i2);cursor:pointer;transition:all .18s}
.nav-hist:hover{border-color:var(--mm);color:var(--mg)}
.nbadge{background:var(--mg);color:#fff;border-radius:50%;width:17px;height:17px;display:inline-flex;align-items:center;justify-content:center;font-size:.58rem;font-weight:700;margin-left:2px}
.nav-book{background:var(--mg);color:#fff;border:none;border-radius:var(--pill);padding:.42rem 1.2rem;font-size:.82rem;font-weight:600;cursor:pointer;transition:background .18s}
.nav-book:hover{background:var(--mg2)}

/* HERO */
.hero{display:grid;grid-template-columns:1fr 1fr;align-items:center;gap:2.5rem;padding:4.5rem 4vw 3.5rem;max-width:1200px;margin:0 auto}
.eyebrow{display:inline-flex;align-items:center;gap:7px;background:var(--ml);color:var(--mg);font-size:.7rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;padding:.28rem .85rem;border-radius:var(--pill);margin-bottom:1.1rem}
.eye-dot{width:5px;height:5px;border-radius:50%;background:var(--mm)}
.hero h1{font-family:'DM Serif Display',serif;font-size:clamp(2rem,3.8vw,3.2rem);line-height:1.15;letter-spacing:-.5px;margin-bottom:1rem}
.hero h1 em{font-style:italic;color:var(--mg)}
.hero-desc{font-size:.95rem;color:var(--i2);line-height:1.78;margin-bottom:1.6rem}
.hero-actions{display:flex;gap:.8rem;flex-wrap:wrap;margin-bottom:1.4rem}
.btn-primary{background:var(--mg);color:#fff;border:none;border-radius:var(--pill);padding:.72rem 1.7rem;font-size:.9rem;font-weight:600;cursor:pointer;transition:background .18s}
.btn-primary:hover{background:var(--mg2)}
.btn-ghost{background:none;color:var(--i2);border:1.5px solid var(--bds);border-radius:var(--pill);padding:.7rem 1.5rem;font-size:.9rem;font-weight:500;cursor:pointer;transition:all .18s}
.btn-ghost:hover{border-color:var(--mm);color:var(--mg)}
.hero-tags{display:flex;flex-wrap:wrap;gap:5px}
.tag{font-size:.66rem;font-weight:600;padding:.18rem .58rem;border-radius:var(--pill)}
.tag-g{background:var(--ml);color:var(--mg)}.tag-p{background:var(--pk);color:var(--pkd)}.tag-a{background:var(--am);color:var(--amd)}

/* Hero Panel */
.hero-panel{background:var(--wh);border-radius:var(--rl);box-shadow:var(--sh2);overflow:hidden;border:1px solid rgba(93,202,165,.15)}
.panel-head{background:var(--mg);padding:.85rem 1.2rem;display:flex;align-items:center;justify-content:space-between}
.panel-title{font-family:'DM Serif Display',serif;font-size:.95rem;font-style:italic;color:rgba(255,255,255,.9)}
.live-pill{display:flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);color:rgba(255,255,255,.9);font-size:.62rem;font-weight:700;padding:.2rem .6rem;border-radius:var(--pill)}
.panel-rows{padding:.5rem 1rem}
.panel-row{display:flex;align-items:center;gap:.6rem;padding:.55rem 0;border-bottom:1px solid rgba(0,0,0,.05)}
.panel-row:last-child{border-bottom:none}
.p-av{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.68rem;flex-shrink:0}
.p-info{flex:1;min-width:0}
.p-name{font-size:.78rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.p-spec{font-size:.64rem;color:var(--i3)}
.p-avail{font-size:.62rem;font-weight:700;padding:.13rem .48rem;border-radius:var(--pill);white-space:nowrap;flex-shrink:0}
.p-yes{background:var(--ml);color:var(--mg)}.p-no{background:#f1efe8;color:var(--i3)}
.panel-foot{background:var(--cr);padding:.6rem 1rem;border-top:1px solid rgba(0,0,0,.06);display:flex;justify-content:space-between}
.panel-foot-txt{font-size:.65rem;color:var(--i3)}.panel-foot-txt b{color:var(--mg)}

/* Avatar color classes */
.av-g{background:var(--ml);color:var(--mg)}.av-p{background:var(--pk);color:var(--pkd)}
.av-a{background:var(--am);color:var(--amd)}.av-b{background:var(--bl);color:var(--bld)}
.av-pu{background:var(--pu);color:var(--pud)}.av-co{background:var(--co);color:var(--cod)}

/* SEARCH */
.search-wrap{max-width:880px;margin:0 auto 3.5rem;padding:0 4vw}
.search-bar{display:flex;align-items:center;gap:.4rem;background:var(--wh);border-radius:var(--pill);padding:.48rem .48rem .48rem 1.3rem;box-shadow:var(--sh2);border:1.5px solid rgba(93,202,165,.2)}
.search-bar input{flex:1;border:none;outline:none;background:transparent;font-size:.88rem;color:var(--ink);min-width:0}
.search-bar input::placeholder{color:var(--i3)}
.search-div{width:1px;height:20px;background:rgba(0,0,0,.1);flex-shrink:0}
.search-bar select{border:none;outline:none;background:transparent;font-size:.8rem;color:var(--i2);padding:0 .3rem;cursor:pointer;max-width:120px}
.search-btn{background:var(--mg);color:#fff;border:none;border-radius:var(--pill);padding:.5rem 1.3rem;font-size:.8rem;font-weight:600;cursor:pointer;white-space:nowrap;transition:background .18s}
.search-btn:hover{background:var(--mg2)}

/* SECTION */
.section{max-width:1200px;margin:0 auto 4.5rem;padding:0 4vw}
.sec-lbl{font-size:.66rem;font-weight:700;letter-spacing:.8px;text-transform:uppercase;color:var(--mm);margin-bottom:.35rem}
.sec-title{font-family:'DM Serif Display',serif;font-size:clamp(1.5rem,2.6vw,2.2rem);margin-bottom:2rem;letter-spacing:-.4px}

/* SPECIALTIES */
.spec-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:.8rem}
.spec-card{background:var(--wh);border-radius:var(--r);padding:1.1rem .8rem;text-align:center;border:1.5px solid transparent;transition:all .2s;cursor:pointer}
.spec-card:hover,.spec-card.active{border-color:var(--mm);background:var(--ml);transform:translateY(-3px);box-shadow:0 6px 20px rgba(93,202,165,.18)}
.spec-icon{font-size:1.8rem;margin-bottom:.4rem;display:block}
.spec-name{font-size:.78rem;font-weight:600}.spec-count{font-size:.64rem;color:var(--i3);margin-top:2px}

/* TOOLBAR */
.toolbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;flex-wrap:wrap;gap:.6rem}
.chips{display:flex;gap:.4rem;flex-wrap:wrap}
.chip{font-size:.72rem;font-weight:500;padding:.27rem .78rem;border-radius:var(--pill);border:1.5px solid rgba(0,0,0,.1);cursor:pointer;background:none;color:var(--i2);transition:all .14s}
.chip:hover,.chip.on{background:var(--mg);color:#fff;border-color:var(--mg)}
.chip-clr{border-color:var(--pkm);color:var(--pkd)}.chip-clr:hover{background:var(--pk);color:var(--pkd);border-color:var(--pkm)}
.sort-sel{font-size:.75rem;color:var(--i2);border:1.5px solid rgba(0,0,0,.1);border-radius:var(--r);padding:.28rem .7rem;background:var(--wh);cursor:pointer;outline:none}

/* DOCTOR GRID */
.docs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(330px,1fr));gap:1.1rem}
.no-results{grid-column:1/-1;text-align:center;padding:2.5rem;color:var(--i3);font-size:.88rem}

/* DOCTOR CARD */
.doc-card{background:var(--wh);border-radius:var(--rl);border:1.5px solid rgba(0,0,0,.06);overflow:hidden;transition:box-shadow .22s,transform .22s;display:flex;flex-direction:column}
.doc-card:hover{box-shadow:0 8px 32px rgba(0,0,0,.1);transform:translateY(-3px)}
.doc-top{padding:1.1rem;display:flex;gap:.8rem;border-bottom:1px solid rgba(0,0,0,.06)}
.doc-av{width:58px;height:58px;border-radius:13px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;flex-shrink:0}
.doc-info{flex:1;min-width:0}
.doc-name-row{display:flex;align-items:center;gap:5px;flex-wrap:wrap;margin-bottom:2px}
.doc-name{font-size:.92rem;font-weight:700}
.online-pill{font-size:.6rem;font-weight:700;background:var(--ml);color:var(--mg);padding:.12rem .4rem;border-radius:var(--pill)}
.doc-spec{font-size:.72rem;color:var(--i3);margin-bottom:4px}
.doc-meta{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.doc-rating{font-size:.7rem;font-weight:700;color:#ef9f27}
.doc-ver{font-size:.6rem;font-weight:700;padding:.12rem .4rem;border-radius:var(--pill);background:var(--ml);color:var(--mg)}
.doc-badge{font-size:.6rem;font-weight:700;padding:.12rem .4rem;border-radius:var(--pill);background:var(--bl);color:var(--bld)}
.doc-quals{margin-top:3px;font-size:.62rem;color:var(--i3)}
.doc-slots{padding:.85rem 1.1rem}
.slots-lbl{font-size:.63rem;font-weight:700;color:var(--i3);text-transform:uppercase;letter-spacing:.45px;margin-bottom:.5rem;display:flex;align-items:center;gap:4px}
.avail-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.dot-on{background:var(--mg)}.dot-off{background:var(--i3)}
.slot-row{display:flex;gap:5px;flex-wrap:wrap}
.slot{font-size:.68rem;font-weight:600;padding:.24rem .68rem;border-radius:var(--pill);cursor:pointer;border:1.5px solid transparent;transition:all .14s;user-select:none}
.slot-free{background:var(--ml);color:var(--mg)}.slot-free:hover{background:var(--mg);color:#fff}
.slot-booked{background:#f1efe8;color:var(--i3);text-decoration:line-through;cursor:default}
.slot-selected{background:var(--mg);color:#fff}
.doc-foot{padding:.8rem 1.1rem;display:flex;align-items:center;justify-content:space-between;background:var(--cr);border-top:1px solid rgba(0,0,0,.06);margin-top:auto}
.fee-txt{font-size:.75rem;color:var(--i2)}.fee-txt b{color:var(--ink);font-size:.84rem}
.foot-btns{display:flex;gap:5px;align-items:center}
.view-btn{background:none;border:1.5px solid rgba(0,0,0,.12);border-radius:var(--pill);padding:.28rem .8rem;font-size:.7rem;font-weight:600;color:var(--i2);cursor:pointer;transition:all .14s}
.view-btn:hover{border-color:var(--mm);color:var(--mg)}
.book-btn{background:var(--mg);color:#fff;border:none;border-radius:var(--pill);padding:.28rem .95rem;font-size:.7rem;font-weight:700;cursor:pointer;transition:background .14s}
.book-btn:hover{background:var(--mg2)}
.no-slot-hint{font-size:.68rem;color:var(--i3);font-style:italic}

/* FEATURES */
.feat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1rem}
.feat-card{background:var(--wh);border-radius:var(--r);padding:1.5rem;border:1px solid rgba(0,0,0,.05);border-top:2.5px solid;position:relative;overflow:hidden}
.feat-card.f-g{border-top-color:var(--mm)}.feat-card.f-p{border-top-color:var(--pkm)}
.feat-card.f-a{border-top-color:var(--amm)}.feat-card.f-b{border-top-color:var(--blm)}
.feat-card.f-pu{border-top-color:var(--pum)}.feat-card.f-co{border-top-color:var(--com)}
.feat-num{font-family:'DM Serif Display',serif;font-size:2.4rem;opacity:.06;position:absolute;top:.5rem;right:.9rem;line-height:1;user-select:none}
.feat-icon{width:40px;height:40px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.15rem;margin-bottom:.8rem}
.fi-g{background:var(--ml)}.fi-p{background:var(--pk)}.fi-a{background:var(--am)}
.fi-b{background:var(--bl)}.fi-pu{background:var(--pu)}.fi-co{background:var(--co)}
.feat-card h3{font-size:.9rem;font-weight:700;margin-bottom:.35rem}
.feat-card p{font-size:.8rem;color:var(--i2);line-height:1.65}

/* HOW IT WORKS */
.steps{display:flex;flex-wrap:wrap}
.step{flex:1;min-width:160px;text-align:center;padding:1.2rem .7rem;position:relative}
.step:not(:last-child)::after{content:'';position:absolute;top:2.2rem;right:-1px;width:1px;height:32px;background:var(--mm)}
.step-num{width:44px;height:44px;border-radius:50%;background:var(--ml);color:var(--mg);font-family:'DM Serif Display',serif;font-size:1.25rem;display:flex;align-items:center;justify-content:center;margin:0 auto .75rem;border:1.5px solid var(--mm);transition:background .2s}
.step:hover .step-num{background:var(--mm);color:#fff}
.step h4{font-size:.82rem;font-weight:700;margin-bottom:.28rem}
.step p{font-size:.74rem;color:var(--i3);line-height:1.58}

/* STATS */
.stats-bar{background:var(--mg);border-radius:var(--rl);padding:2.4rem 1rem;display:flex;justify-content:space-around;flex-wrap:wrap;gap:1.5rem;margin:0 4vw 4.5rem}
.stat{text-align:center}
.stat-num{font-family:'DM Serif Display',serif;font-size:2.5rem;color:#fff;display:block;line-height:1}
.stat-lbl{font-size:.78rem;color:rgba(255,255,255,.65);margin-top:.2rem}

/* FOOTER */
.footer{background:var(--ink);color:rgba(255,255,255,.5);text-align:center;padding:2rem 4vw;font-size:.78rem}
.footer b{color:rgba(255,255,255,.8)}

/* MODAL */
.overlay{display:none;position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.5);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:.75rem}
.overlay.open{display:flex}
.modal{background:var(--wh);border-radius:var(--rl);max-width:480px;width:100%;box-shadow:var(--sh2);overflow:hidden;animation:slideUp .22s ease}
.modal-lg{max-width:540px}.modal-hist{max-width:500px}
@keyframes slideUp{from{transform:translateY(22px);opacity:0}to{transform:translateY(0);opacity:1}}
.m-head{background:var(--mg);padding:1.1rem 1.3rem;display:flex;align-items:center;justify-content:space-between}
.m-head h3{font-family:'DM Serif Display',serif;font-size:1rem;color:#fff}
.m-close{background:rgba(255,255,255,.18);border:none;color:#fff;width:26px;height:26px;border-radius:50%;font-size:.88rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background .14s}
.m-close:hover{background:rgba(255,255,255,.3)}
.m-body{padding:1.3rem}
.m-doc-row{display:flex;gap:.8rem;align-items:center;margin-bottom:1.1rem;padding-bottom:1rem;border-bottom:1px solid rgba(0,0,0,.07)}
.m-doc-av{width:46px;height:46px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;flex-shrink:0}
.m-doc-name{font-weight:700;font-size:.9rem}.m-doc-sub{font-size:.7rem;color:var(--i3)}
.slot-confirm{background:var(--ml);color:var(--mg);padding:.55rem .85rem;border-radius:var(--r);font-size:.76rem;font-weight:700;margin-bottom:.9rem;display:flex;align-items:center;gap:5px}
.field{margin-bottom:.75rem}
.field label{font-size:.63rem;font-weight:700;color:var(--i3);display:block;margin-bottom:.3rem;text-transform:uppercase;letter-spacing:.4px}
.field input,.field textarea{width:100%;border:1.5px solid rgba(0,0,0,.12);border-radius:var(--r);padding:.55rem .8rem;font-size:.86rem;outline:none;color:var(--ink);background:var(--cr);transition:border-color .14s}
.field input:focus,.field textarea:focus{border-color:var(--mm)}
.field textarea{resize:vertical;min-height:62px}
.confirm-btn{width:100%;background:var(--mg);color:#fff;border:none;border-radius:var(--pill);padding:.78rem;font-size:.9rem;font-weight:700;cursor:pointer;margin-top:.3rem;transition:background .14s}
.confirm-btn:hover{background:var(--mg2)}

/* SUCCESS */
.success{text-align:center;padding:.8rem 0}
.s-icon{width:54px;height:54px;border-radius:50%;background:var(--ml);color:var(--mg);font-size:1.5rem;display:flex;align-items:center;justify-content:center;margin:0 auto .9rem}
.success h3{font-family:'DM Serif Display',serif;font-size:1.2rem;margin-bottom:.35rem}
.success p{font-size:.8rem;color:var(--i2);margin-bottom:.8rem;line-height:1.65}
.appt-box{background:var(--cr);border-radius:var(--r);padding:.8rem .95rem;text-align:left;font-size:.76rem;color:var(--i2);line-height:1.88;margin-bottom:.85rem;border:1px solid rgba(0,0,0,.06)}
.appt-box b{color:var(--ink)}

/* PROFILE */
.prof-scroll{max-height:80vh;overflow-y:auto}
.prof-hero{background:linear-gradient(130deg,var(--mg),var(--mg2));padding:1.5rem 1.3rem;display:flex;gap:1rem;align-items:center}
.prof-av{width:64px;height:64px;border-radius:15px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.3rem;background:rgba(255,255,255,.18);color:#fff;flex-shrink:0}
.prof-title .pn{font-family:'DM Serif Display',serif;font-size:1.1rem;color:#fff;margin-bottom:2px}
.prof-title .ps{font-size:.74rem;color:rgba(255,255,255,.76)}
.prof-title .pr{font-size:.7rem;color:#ffd700;margin-top:3px}
.prof-body{padding:1.2rem 1.3rem}
.prof-sec{margin-bottom:1.1rem}
.prof-sec h4{font-size:.62rem;font-weight:700;text-transform:uppercase;letter-spacing:.6px;color:var(--mm);margin-bottom:.5rem}
.prof-sec p{font-size:.78rem;color:var(--i2);line-height:1.68}
.info-grid{display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
.info-item{background:var(--cr);border-radius:var(--r);padding:.6rem .75rem;border:1px solid rgba(0,0,0,.06)}
.info-item .key{font-size:.6rem;font-weight:700;color:var(--i3);text-transform:uppercase;letter-spacing:.35px;margin-bottom:2px}
.info-item .val{font-size:.8rem;font-weight:600;color:var(--ink)}
.treats-row{display:flex;flex-wrap:wrap;gap:5px}
.treat-tag{font-size:.66rem;background:var(--cr);border:1px solid rgba(0,0,0,.08);border-radius:var(--pill);padding:.18rem .62rem;color:var(--i2)}
.badge-row{display:flex;flex-wrap:wrap;gap:5px}
.honor-tag{font-size:.66rem;background:var(--am);color:var(--amd);border-radius:var(--pill);padding:.18rem .65rem;font-weight:700}
.review-card{background:var(--cr);border-radius:var(--r);padding:.7rem .85rem;margin-bottom:.5rem;border:1px solid rgba(0,0,0,.06)}
.rev-top{display:flex;align-items:center;gap:.4rem;margin-bottom:.25rem}
